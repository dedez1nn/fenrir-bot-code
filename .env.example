## ─── Discord Bot ──────────────────────────────────────────────────────────────
TOKEN=
ACCESS_TOKEN=
# ID da guild principal — usado para carregar server_config no boot
GUILD_ID=

ENVIRONMENT=development
LOG_LEVEL=INFO

## ─── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_DB=fenrir
POSTGRES_USER=fenrir
POSTGRES_PASSWORD=
# Em docker-compose o host é "postgres"; em dev local pode ser "localhost".
DATABASE_URL=postgresql://fenrir:senha@postgres:5432/fenrir

## ─── API / Painel admin (Fase 5) ──────────────────────────────────────────────
API_PORT=8000
# Discord OAuth2 (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8000/auth/callback
# Segredo para assinar JWT da sessão do painel (gere com `openssl rand -hex 32`)
JWT_SECRET=
# Segredo HMAC do webhook do Mercado Pago
MP_WEBHOOK_SECRET=
# Origens permitidas (CSV) — em produção, restrinja ao domínio do painel
CORS_ORIGINS=*

## ─── Riot Games API ──────────────────────────────────────────────────────────
# Obtenha em: https://developer.riotgames.com
RIOT_API_KEY=
RIOT_REGION=br1

## ─── Steam API ───────────────────────────────────────────────────────────────
# Obtenha em: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

## ─── GNews API ───────────────────────────────────────────────────────────────
# Obtenha em: https://gnews.io
GNEWS_API_KEY=

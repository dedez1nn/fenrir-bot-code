TOKEN=
ACCESS_TOKEN=

ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── Riot Games API ────────────────────────────────────────────────────────────
# Obtenha em: https://developer.riotgames.com
# Para uso em produção, solicite uma Production Key no portal acima.
# A Development Key expira a cada 24h e tem rate limit muito baixo.
RIOT_API_KEY=
# Região padrão do servidor. Opções: br1, na1, euw1, eun1, la1, la2, kr, jp1, oc1, tr1, ru
RIOT_REGION=br1

# ─── Steam API ─────────────────────────────────────────────────────────────────
# Obtenha em: https://steamcommunity.com/dev/apikey
# A Steam API Key é instantânea e gratuita.
STEAM_API_KEY=

# ─── GNews API ─────────────────────────────────────────────────────────────────
# Obtenha em: https://gnews.io (plano gratuito: 100 requisições/dia)
GNEWS_API_KEY=
